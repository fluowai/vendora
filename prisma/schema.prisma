generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Dev:   provider = "sqlite"     DATABASE_URL="file:./dev.db"
  // Prod:  provider = "postgresql"  DATABASE_URL="postgresql://..."
  // O Dockerfile substitui sqlite por postgresql automaticamente no build
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Plan {
  id              String   @id @default(uuid())
  name            String
  price           Float    @default(0)
  maxAgents       Int      @default(1)
  maxConversations Int     @default(500)
  maxChannels     Int      @default(1)
  maxUsers        Int      @default(1)
  features        Json?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenants         Tenant[]
  whiteLabels     WhiteLabel[]
}

model WhiteLabel {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  document        String?
  email           String?
  phone           String?
  status          String   @default("active")
  customDomain    String?  @unique
  branding        Json?
  limits          Json?
  billingConfig   Json?
  planId          String?
  plan            Plan?    @relation(fields: [planId], references: [id])
  ownerUserId     String?
  owner           User?    @relation("WhiteLabelOwner", fields: [ownerUserId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenants         Tenant[]
  users           User[]   @relation("WhiteLabelUsers")

  @@index([slug])
  @@index([status])
  @@index([planId])
  @@index([ownerUserId])
}

model Tenant {
  id        String   @id @default(uuid())
  whiteLabelId String?
  whiteLabel   WhiteLabel? @relation(fields: [whiteLabelId], references: [id])
  name      String
  slug      String   @unique
  document  String?
  email     String?
  phone     String?
  status    String   @default("active")
  planId    String?
  plan      Plan?    @relation(fields: [planId], references: [id])

  /// Whitelabel branding config
  branding  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  roles             Role[]
  departments       Department[]
  channels          Channel[]
  contacts          Contact[]
  conversations     Conversation[]
  messages          Message[]
  deals             Deal[]
  tickets           Ticket[]
  ombudsmanCases    OmbudsmanCase[]
  aiAgents          AiAgent[]
  knowledgeBases    KnowledgeBase[]
  calendars         Calendar[]
  appointments      Appointment[]
  auditLogs         AuditLog[]
  pabxExtensions    PabxExtension[]
  pabxQueues        PabxQueue[]
  pabxIvrMenus      PabxIvrMenu[]
  pabxCallRoutes    PabxCallRoute[]
  pabxCallLogs      PabxCallLog[]
  campaigns         DialingCampaign[]
  agentFlows        AgentFlow[]
  flowRuns          FlowRun[]

  @@index([slug])
  @@index([whiteLabelId])
  @@index([planId])
  @@index([status])
}

model AgentFlow {
  id                 String   @id @default(uuid())
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  name               String
  description        String?
  status             String   @default("draft") // draft | active | paused | archived
  trigger            String   @default("manual") // manual | new_message | webhook
  channel            String?
  publicEnabled      Boolean  @default(false)
  publishedVersionId String?
  metadata           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  versions           FlowVersion[]
  runs               FlowRun[]

  @@index([tenantId, status])
  @@index([tenantId, trigger])
}

model FlowVersion {
  id          String    @id @default(uuid())
  flowId      String
  flow        AgentFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  version     Int
  status      String    @default("draft") // draft | published | archived
  graph       Json
  createdBy   String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  runs        FlowRun[]

  @@unique([flowId, version])
  @@index([flowId, status])
}

model FlowRun {
  id             String       @id @default(uuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  flowId         String
  flow           AgentFlow    @relation(fields: [flowId], references: [id])
  versionId      String
  version        FlowVersion  @relation(fields: [versionId], references: [id])
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  contactId      String?
  contact        Contact?     @relation(fields: [contactId], references: [id])
  status         String       @default("running") // running | waiting_input | completed | failed
  currentNodeId  String?
  variables      Json?
  lastInput      String?
  lastError      String?
  startedAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  completedAt    DateTime?

  steps          FlowRunStep[]

  @@index([tenantId, status])
  @@index([flowId, status])
  @@index([conversationId, status])
}

model FlowRunStep {
  id        String   @id @default(uuid())
  runId     String
  run       FlowRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  nodeId    String
  nodeType  String
  input     Json?
  output    Json?
  status    String   @default("completed") // completed | waiting_input | failed
  createdAt DateTime @default(now())

  @@index([runId, createdAt])
}

model User {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  whiteLabelId  String?
  whiteLabel    WhiteLabel? @relation("WhiteLabelUsers", fields: [whiteLabelId], references: [id])
  name          String
  email         String   @unique
  passwordHash  String
  avatarUrl     String?
  status        String   @default("active")
  isSuperadmin  Boolean  @default(false)
  platformRole  String   @default("none") // none | mega_admin
  roleScope     String   @default("tenant") // platform | whitelabel | tenant
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ownedWhiteLabels WhiteLabel[] @relation("WhiteLabelOwner")
  userRoles     UserRole[]
  conversations Conversation[] @relation("AssignedUser")
  deals         Deal[]         @relation("AssignedUser")
  tickets       Ticket[]       @relation("AssignedUser")
  ombudsmanCases OmbudsmanCase[] @relation("AssignedUser")
  appointments  Appointment[]  @relation("AppointmentAssignedUser")
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  pabxExtensions PabxExtension[]

  @@index([tenantId])
  @@index([whiteLabelId])
  @@index([platformRole])
  @@index([roleScope])
  @@index([email])
}

model Role {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  
  permissions Permission[]
  userRoles   UserRole[]
}

model Permission {
  id      String @id @default(uuid())
  roleId  String
  role    Role   @relation(fields: [roleId], references: [id])
  action  String
  subject String
}

model UserRole {
  id      String @id @default(uuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  roleId  String
  role    Role   @relation(fields: [roleId], references: [id])
}

model Department {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  
  conversations Conversation[]
  tickets       Ticket[]
  ombudsmanCases OmbudsmanCase[]
  pabxExtensions PabxExtension[]
}

model Channel {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  provider  String
  config    Json?
  status    String   @default("active")

  instances ChannelInstance[]
}

model ChannelInstance {
  id        String   @id @default(uuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id])
  name      String
  status    String
  config    Json?

  conversations Conversation[]
}

model Contact {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  email       String?
  phone       String?
  document    String?
  companyName String?
  city        String?
  state       String?
  source      String?
  score       Int?
  status      String   @default("active")
  avatarUrl   String?
  pushName    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  identities    ContactIdentity[]
  conversations Conversation[]
  messages      Message[]
  deals         Deal[]
  tickets       Ticket[]
  ombudsmanCases OmbudsmanCase[]
  appointments    Appointment[]
  campaignContacts CampaignContact[]
  flowRuns        FlowRun[]

  @@index([tenantId])
  @@index([phone])
  @@index([email])
}

model ContactIdentity {
  id         String   @id @default(uuid())
  tenantId   String
  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id])
  channel    String
  provider   String
  externalId String
  username   String?
  phone      String?
  email      String?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Conversation {
  id                String   @id @default(uuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  contactId         String
  contact           Contact  @relation(fields: [contactId], references: [id])
  channelInstanceId String
  channelInstance   ChannelInstance @relation(fields: [channelInstanceId], references: [id])
  channel           String
  status            String
  assignedUserId    String?
  assignedUser      User?    @relation("AssignedUser", fields: [assignedUserId], references: [id])
  departmentId      String?
  department        Department? @relation(fields: [departmentId], references: [id])
  lastMessageAt     DateTime?
  aiEnabled         Boolean  @default(true)
  slaDueAt          DateTime?
  priority          String   @default("normal")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  messages          Message[]
  deals             Deal[]
  tickets           Ticket[]
  ombudsmanCases    OmbudsmanCase[]
  appointments      Appointment[]
  flowRuns          FlowRun[]

  @@index([tenantId, status])
  @@index([tenantId, assignedUserId])
  @@index([contactId])
  @@index([lastMessageAt])
}

model Message {
  id                String   @id @default(uuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  conversationId    String
  conversation      Conversation @relation(fields: [conversationId], references: [id])
  contactId         String?
  contact           Contact? @relation(fields: [contactId], references: [id])
  senderType        String
  senderId          String
  channel           String
  providerMessageId String?
  messageType       String
  content           String
  mediaUrl          String?
  mediaMimeType     String?
  mediaName         String?
  mediaSize         Int?
  metadata          Json?
  sentAt            DateTime @default(now())
  deliveredAt       DateTime?
  readAt            DateTime?
  createdAt         DateTime @default(now())

  @@index([conversationId, sentAt])
  @@index([tenantId])
  @@index([senderType])
}

model Funnel {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  
  stages    FunnelStage[]
  deals     Deal[]
}

model FunnelStage {
  id        String   @id @default(uuid())
  funnelId  String
  funnel    Funnel   @relation(fields: [funnelId], references: [id])
  name      String
  order     Int

  deals     Deal[]
}

model Deal {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  contactId       String
  contact         Contact  @relation(fields: [contactId], references: [id])
  conversationId  String?
  conversation    Conversation? @relation(fields: [conversationId], references: [id])
  funnelId        String
  funnel          Funnel   @relation(fields: [funnelId], references: [id])
  stageId         String
  stage           FunnelStage @relation(fields: [stageId], references: [id])
  title           String
  value           Float?
  status          String
  source          String?
  temperature     String?
  score           Int?
  assignedUserId  String?
  assignedUser    User?    @relation("AssignedUser", fields: [assignedUserId], references: [id])
  expectedCloseDate DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Ticket {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  contactId       String
  contact         Contact  @relation(fields: [contactId], references: [id])
  conversationId  String?
  conversation    Conversation? @relation(fields: [conversationId], references: [id])
  title           String
  description     String
  status          String
  priority        String
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id])
  assignedUserId  String?
  assignedUser    User?    @relation("AssignedUser", fields: [assignedUserId], references: [id])
  slaDueAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OmbudsmanCase {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  protocolNumber  String   @unique
  contactId       String?
  contact         Contact? @relation(fields: [contactId], references: [id])
  conversationId  String?
  conversation    Conversation? @relation(fields: [conversationId], references: [id])
  type            String
  category        String
  description     String
  status          String
  priority        String
  severity        String
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id])
  assignedUserId  String?
  assignedUser    User?    @relation("AssignedUser", fields: [assignedUserId], references: [id])
  anonymous       Boolean  @default(false)
  slaDueAt        DateTime?
  officialResponse String?
  closedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AiAgent {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  name            String
  segment         String
  description     String?
  modelProvider   String
  modelName       String
  temperature     Float    @default(0.7)
  basePrompt      String
  knowledgeBaseId String?
  avatar          String?
  parentId        String?
  price           Float?
  status          String   @default("active")
  channels        Json?
  isPublished     Boolean  @default(false)
  installs        Int      @default(0)
  rating          Float    @default(0)
  authorId        String   @default("system")
  authorName      String   @default("Vendaora AI")
  tags            Json?
  enabled         Boolean  @default(true)
  handoffRules    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointments    Appointment[]

  @@index([tenantId, enabled, status])
  @@index([segment])
}

model Calendar {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  timezone    String   @default("America/Sao_Paulo")
  slotMinutes Int      @default(60)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  availability CalendarAvailability[]
  appointments Appointment[]
}

model CalendarAvailability {
  id         String   @id @default(uuid())
  calendarId String
  calendar   Calendar @relation(fields: [calendarId], references: [id])
  weekday    Int
  startTime  String
  endTime    String
  isActive   Boolean  @default(true)
}

model Appointment {
  id             String   @id @default(uuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  calendarId     String
  calendar       Calendar @relation(fields: [calendarId], references: [id])
  contactId      String?
  contact        Contact? @relation(fields: [contactId], references: [id])
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  aiAgentId      String?
  aiAgent        AiAgent? @relation(fields: [aiAgentId], references: [id])
  assignedUserId String?
  assignedUser   User?    @relation("AppointmentAssignedUser", fields: [assignedUserId], references: [id])
  title          String
  description    String?
  status         String   @default("scheduled")
  startsAt       DateTime
  endsAt         DateTime
  source         String   @default("ai")
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model KnowledgeBase {
  id        String     @id @default(uuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  name      String
  documents Document[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Document {
  id              String       @id @default(uuid())
  knowledgeBaseId String
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id])
  name            String
  type            String
  content         String
  chunks          Json?
  createdAt       DateTime     @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tokenHash String @unique
  family    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([tokenHash])
  @@index([userId])
  @@index([family])
}

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    String
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([action])
  @@index([entityType, entityId])
}

// ===== PABX Models =====

model PabxExtension {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  extension   String   // Número do ramal (ex: "101")
  name        String   // Nome do ramal
  description String?
  userId      String?  // Usuário associado ao ramal
  user        User?    @relation(fields: [userId], references: [id])
  departmentId String?
  department  Department? @relation(fields: [departmentId], references: [id])
  status      String   @default("active") // active | paused | offline
  ringTimeout Int      @default(30)       // segundos
  callLimit   Int      @default(2)        // máx chamadas simultâneas
  mobile      String?  // Número WhatsApp/telefone do ramal
  email       String?
  voicemail   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  queueMembers PabxQueueMember[]

  @@unique([tenantId, extension])
  @@index([tenantId, status])
  @@index([userId])
}

model PabxQueue {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  strategy    String   @default("ringall")     // ringall | leastrecent | fewestcalls | random
  ringTimeout Int      @default(30)            // segundos para cada toque
  maxWaitTime Int      @default(300)           // tempo máximo na fila (segundos)
  maxCallers  Int      @default(10)            // máx chamadores na fila
  musicOnHold String?  // URL do áudio de espera
  welcomeMsg  String?  // Mensagem de boas-vindas
  status      String   @default("active")      // active | paused
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     PabxQueueMember[]

  @@index([tenantId, status])
}

model PabxQueueMember {
  id          String        @id @default(uuid())
  queueId     String
  queue       PabxQueue     @relation(fields: [queueId], references: [id], onDelete: Cascade)
  extensionId String
  extension   PabxExtension @relation(fields: [extensionId], references: [id], onDelete: Cascade)
  priority    Int           @default(1)
  timeout     Int           @default(30)

  @@unique([queueId, extensionId])
}

model PabxIvrMenu {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String   // Nome do menu (ex: "Menu Principal")
  description String?
  greeting    String?  // Texto da saudação ou URL do áudio TTS
  greetingType String  @default("text")   // text | audio
  timeout     Int      @default(10)       // segundos aguardando input
  timeoutDestType String? // extension | queue | ivr
  timeoutDestId   String?
  invalidDestType String? // extension | queue | ivr
  invalidDestId   String?
  language    String   @default("pt-BR")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  options     PabxIvrOption[]
  callRoutes  PabxCallRoute[] @relation("IvrDestination")

  @@index([tenantId, status])
}

model PabxIvrOption {
  id              String      @id @default(uuid())
  ivrMenuId       String
  ivrMenu         PabxIvrMenu @relation(fields: [ivrMenuId], references: [id], onDelete: Cascade)
  digit           String      // "1" a "9", "0", "*", "#"
  description     String?
  destinationType String      // extension | queue | ivr
  destinationId   String
  createdAt       DateTime    @default(now())

  @@unique([ivrMenuId, digit])
}

model PabxCallRoute {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  name            String
  description     String?
  source          String   // Número de origem ou padrão (ex: "*" = todas)
  destinationType String   // extension | queue | ivr | voicemail
  destinationId   String?
  ivrMenuId       String?  // Se destinationType = "ivr"
  ivrMenu         PabxIvrMenu? @relation("IvrDestination", fields: [ivrMenuId], references: [id])
  priority        Int      @default(0)
  timeSchedule    Json?    // Agendamento (JSON com dias/horários)
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status])
  @@index([source])
}

model PabxCallLog {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  callId          String   @unique
  sessionId       String?  // WaCalls session ID
  callerId        String   // Número do chamador
  callerName      String?
  direction       String   // inbound | outbound | internal
  destinationType String?  // extension | queue | ivr
  destinationId   String?
  extensionNumber String?
  queueName       String?
  ivrName         String?
  status          String   // ringing | connected | ended | missed | failed
  duration        Int?     // segundos
  ringDuration    Int?     // tempo de toque
  recordingUrl    String?
  tags            Json?    // Tags para categorização
  notes           String?
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime @default(now())

  @@index([tenantId, startedAt])
  @@index([callerId])
  @@index([callId])
  @@index([status])
}

model WaCallRecord {
  id        String   @id @default(uuid())
  sessionId String
  callId    String   @unique
  owner     String?
  direction String
  peer      String
  status    String
  startedAt DateTime
  endedAt   DateTime?
  endReason String?
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([startedAt])
}

model DialingCampaign {
  id          String     @id @default(uuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  status      String     @default("draft") // draft | active | paused | completed | cancelled
  mode        String     @default("predictive") // predictive | progressive | preview
  scheduleStart DateTime?
  scheduleEnd   DateTime?
  maxAttempts  Int       @default(3)
  intervalSeconds Int    @default(60)
  agentId      String?   // AiAgent id to connect answered calls
  sessionId    String?   // WaCalls session to use for calls
  callerId     String?   // Caller ID / number to display
  dailyLimit   Int?      // Max calls per day
  totalContacts Int     @default(0)
  calledCount  Int      @default(0)
  answeredCount Int     @default(0)
  successCount  Int     @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  contacts     CampaignContact[]
  attempts     CallAttempt[]

  @@index([tenantId, status])
}

model CampaignContact {
  id         String   @id @default(uuid())
  campaignId String
  campaign   DialingCampaign @relation(fields: [campaignId], references: [id])
  contactId  String?
  contact    Contact? @relation(fields: [contactId], references: [id])
  name       String?
  phone      String
  email      String?
  metadata   Json?
  status     String   @default("pending") // pending | called | answered | failed | skipped
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  attempts   CallAttempt[]

  @@index([campaignId, status])
  @@index([phone])
}

model CallAttempt {
  id            String   @id @default(uuid())
  campaignId    String
  campaign      DialingCampaign @relation(fields: [campaignId], references: [id])
  contactId     String
  campaignContact CampaignContact @relation(fields: [contactId], references: [id])
  sessionId     String?  // WaCalls session used
  callId        String?  // WaCalls call ID
  attempt       Int      @default(1)
  status        String   @default("pending") // pending | ringing | connected | no_answer | busy | failed | answered
  duration      Int?     // seconds
  direction     String   @default("outbound")
  result        String?  // Resultado da tentativa
  errorMessage  String?
  startedAt     DateTime?
  endedAt       DateTime?
  recordingUrl  String?
  createdAt     DateTime @default(now())

  @@index([campaignId])
  @@index([status])
  @@index([callId])
}
