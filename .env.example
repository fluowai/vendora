# ==========================================
# Database (local dev = SQLite)
# Para usar Supabase PostgreSQL, descomente a linha abaixo
# e comente a linha DATABASE_URL do SQLite
# ==========================================
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres"

# ==========================================
# Redis (opcional - necessário para filas)
# ==========================================
REDIS_URL="redis://localhost:6379"

# ==========================================
# Supabase (opcional - só usa se configurado)
# ==========================================
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="vendora-assets"

# ==========================================
# Auth - CHANGE THESE IN PRODUCTION!
# Gere secrets fortes com: openssl rand -hex 64
# ==========================================
JWT_SECRET="change-this-to-a-random-secret-in-production"
JWT_REFRESH_SECRET="change-this-to-another-random-secret"

# URLs
APP_URL="http://localhost:5173"
API_URL="http://localhost:3333"
FRONTEND_URL="http://localhost:5173"

# AI Providers (configure at least one)
GEMINI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GROQ_API_KEY=""

# Meta/WhatsApp (optional)
META_APP_ID=""
META_APP_SECRET=""
META_VERIFY_TOKEN=""
WHATSAPP_CLOUD_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# SMTP (optional)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# Security
WEBHOOK_SECRET=""
ENCRYPTION_KEY=""

# Chatwoot adapter (optional)
CHATWOOT_WEBHOOK_SECRET=""

# whatsmeow bridge (optional sidecar)
WHATSMEOW_BRIDGE_URL="http://localhost:4000"
WHATSMEOW_BRIDGE_SECRET=""
WHATSMEOW_WEBHOOK_URL="http://localhost:3333/api/integrations/whatsmeow/incoming?tenantId=seed-tenant"

# Node
NODE_ENV="development"
PORT="3333"

