# ==========================================
# Database
# ==========================================
# Dev (SQLite):
# DATABASE_URL="file:./dev.db"
# Prod (PostgreSQL via Docker Compose):
# DATABASE_URL="postgresql://postgres:vendaora_secret@localhost:5432/vendaora"
# Prod (Supabase / external):
DATABASE_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres"

# ==========================================
# Redis (obrigatório para filas BullMQ)
# ==========================================
REDIS_URL="redis://localhost:6379"

# ==========================================
# Auth — Gere secrets fortes com: openssl rand -hex 64
# ==========================================
JWT_SECRET="change-this-to-a-random-secret-in-production"
JWT_REFRESH_SECRET="change-this-to-another-random-secret"

# ==========================================
# URLs
# ==========================================
APP_URL="http://localhost:5173"
API_URL="http://localhost:3333"
FRONTEND_URL="http://localhost:5173"

# ==========================================
# AI Providers (configure ao menos um)
# ==========================================
GEMINI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GROQ_API_KEY=""

# ==========================================
# Supabase (opcional — auth social + storage)
# ==========================================
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="vendora-assets"

# ==========================================
# Meta / WhatsApp (NÃO USAR — apenas whatsmeow)
# ==========================================
META_APP_ID=""
META_APP_SECRET=""
META_VERIFY_TOKEN="vendaora_verify"
WHATSAPP_CLOUD_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# ==========================================
# Google OAuth (opcional)
# ==========================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ==========================================
# SMTP (opcional)
# ==========================================
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# ==========================================
# Security / Webhooks
# ==========================================
WEBHOOK_SECRET=""
ENCRYPTION_KEY=""
CHATWOOT_WEBHOOK_SECRET=""

# ==========================================
# whatsmeow-bridge (Go sidecar — WhatsApp não-oficial)
# Porta 4000, container separado no Docker
# ==========================================
WHATSMEOW_BRIDGE_URL="http://localhost:4000"
WHATSMEOW_BRIDGE_SECRET="change-this-bridge-secret"
WHATSMEOW_WEBHOOK_URL="http://localhost:3333/api/integrations/whatsmeow/incoming?tenantId=seed-tenant"

# MinIO / S3-compatible media storage
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_BUCKET="vendora-media"
MINIO_PUBLIC_URL="http://localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"

# ==========================================
# WaCalls (Go VoIP — chamadas WhatsApp)
# Porta 8081, container separado no Docker
# ==========================================
VOICE_GATEWAY="wacalls"
WACALLS_URL=""
WACALLS_PORT=8081
WACALLS_DB_PATH="./wacalls/wacalls.db"

# ==========================================
# WAHA+ (WhatsApp HTTP API Plus - waha-voip)
# Opcao 2.0 — alternativa ao whatsmeow + wacalls
# Roda como container Docker
# ==========================================
WAHAPLUS_URL=""
WAHAPLUS_PORT="3000"
# WAHAPLUS_IMAGE="devlikeapro/waha-plus"
WAHAPLUS_IMAGE="devlikeapro/waha"
# WAHAPLUS_LICENSE=""

# ==========================================
# Voice Gateway - "wacalls" ou "wahaplus"
# ==========================================
VOICE_GATEWAY="wacalls"

# ==========================================
# Error Tracking (Sentry)
# ==========================================
SENTRY_DSN=""

# ==========================================
# Node
# ==========================================
NODE_ENV="development"
PORT="3333"
