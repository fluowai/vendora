# ==========================================
# Database (dev = SQLite, production = Supabase PostgreSQL)
# ==========================================
# Dev: SQLite (já funciona, sem dependências externas)
DATABASE_URL="file:./dev.db"
# Prod / Supabase: descomente abaixo e comente a linha SQLite
# Altere os valores conforme seu projeto Supabase:
# DATABASE_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres"
#
# Para migrar do SQLite para o Supabase:
# 1. Crie um projeto em https://supabase.com
# 2. Vá em Settings > Database > Connection string (URI)
# 3. Copie a string e coloque na DATABASE_URL
# 4. Altere o schema.prisma: provider = "postgresql" (em vez de sqlite)
# 5. Execute: npx prisma migrate deploy
# 6. Execute: npm run db:seed

# ==========================================
# Redis (opcional - necessário para filas)
# ==========================================
REDIS_URL="redis://localhost:6379"

# ==========================================
# Supabase (opcional - auth e storage)
# ==========================================
# Encontre estas credenciais em: Settings > API
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="vendora-assets"

# ==========================================
# Auth - CHANGE THESE IN PRODUCTION!
# Gere secrets fortes com: openssl rand -hex 64
# ==========================================
JWT_SECRET="change-this-to-a-random-secret-in-production"
JWT_REFRESH_SECRET="change-this-to-another-random-secret"

# URLs
APP_URL="http://localhost:5173"
API_URL="http://localhost:3333"
FRONTEND_URL="http://localhost:5173"

# AI Providers (configure at least one)
GEMINI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GROQ_API_KEY=""

# Meta/WhatsApp (optional)
META_APP_ID=""
META_APP_SECRET=""
META_VERIFY_TOKEN=""
WHATSAPP_CLOUD_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# SMTP (optional)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# Security
WEBHOOK_SECRET=""
ENCRYPTION_KEY=""

# Chatwoot adapter (optional)
CHATWOOT_WEBHOOK_SECRET=""

# whatsmeow bridge (optional sidecar)
WHATSMEOW_BRIDGE_URL="http://localhost:4000"
WHATSMEOW_BRIDGE_SECRET=""
WHATSMEOW_WEBHOOK_URL="http://localhost:3333/api/integrations/whatsmeow/incoming?tenantId=seed-tenant"

# Node
NODE_ENV="development"
PORT="3333"

