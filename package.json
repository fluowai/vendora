{
  "name": "vendaora-360",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "start:dev": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "start:bridge": "cd whatsmeow-bridge && .\\whatsmeow-bridge.exe",
    "wacalls:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-wacalls.ps1",
    "wacalls:start": "cd wacalls && .\\wacalls-server.exe -addr :8081 -db wacalls.db",
    "wahaplus:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-wahaplus.ps1",
    "wahaplus:start": "docker run -d --rm --name vendora-wahaplus -p 3000:3000 devlikeapro/waha",
    "wahaplus:stop": "docker stop vendora-wahaplus",
    "clean": "if (Test-Path dist) { Remove-Item -Recurse -Force dist }",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "backup": "pwsh scripts/backup.ps1"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@prisma/client": "^6.4.1",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.1.14",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-react": "^5.0.4",
    "@xyflow/react": "^12.11.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "date-fns": "^4.2.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "minio": "^8.0.7",
    "motion": "^12.23.24",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.20.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "playwright": "^1.61.1",
    "prisma": "^6.4.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
